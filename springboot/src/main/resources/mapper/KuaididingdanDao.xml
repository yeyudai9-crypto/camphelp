<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.KuaididingdanDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.KuaididingdanEntity" id="kuaididingdanMap">
        <result property="kuaididanhao" column="kuaididanhao"/>
        <result property="kuaidimingcheng" column="kuaidimingcheng"/>
        <result property="kuaidileixing" column="kuaidileixing"/>
        <result property="jietu" column="jietu"/>
        <result property="kuaidibeizhu" column="kuaidibeizhu"/>
        <result property="daiqufeiyong" column="daiqufeiyong"/>
        <result property="zhanghao" column="zhanghao"/>
        <result property="zhuangtai" column="zhuangtai"/>
        <result property="shouji" column="shouji"/>
        <result property="mudedizhi" column="mudedizhi"/>
        <result property="quhuodizhi" column="quhuodizhi"/>
        <result property="storeupnum" column="storeupnum"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.KuaididingdanVO" >
		SELECT * FROM kuaididingdan  kuaididingdan         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.KuaididingdanVO" >
		SELECT  kuaididingdan.* FROM kuaididingdan  kuaididingdan 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.KuaididingdanView" >

		SELECT  kuaididingdan.* FROM kuaididingdan  kuaididingdan 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.KuaididingdanView" >
		SELECT * FROM kuaididingdan  kuaididingdan <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM kuaididingdan
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM kuaididingdan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM kuaididingdan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM kuaididingdan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM kuaididingdan
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>




</mapper>
