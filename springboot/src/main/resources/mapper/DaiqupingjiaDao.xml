<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.DaiqupingjiaDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.DaiqupingjiaEntity" id="daiqupingjiaMap">
        <result property="kuaididanhao" column="kuaididanhao"/>
        <result property="kuaidimingcheng" column="kuaidimingcheng"/>
        <result property="jietu" column="jietu"/>
        <result property="kuaidileixing" column="kuaidileixing"/>
        <result property="kuaidibeizhu" column="kuaidibeizhu"/>
        <result property="daiqufeiyong" column="daiqufeiyong"/>
        <result property="zhanghao" column="zhanghao"/>
        <result property="shouji" column="shouji"/>
        <result property="quhuodizhi" column="quhuodizhi"/>
        <result property="mudedizhi" column="mudedizhi"/>
        <result property="peisongzhanghao" column="peisongzhanghao"/>
        <result property="lianxidianhua" column="lianxidianhua"/>
        <result property="pingjiashijian" column="pingjiashijian"/>
        <result property="pingfen" column="pingfen"/>
        <result property="pingjia" column="pingjia"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.DaiqupingjiaVO" >
		SELECT * FROM daiqupingjia  daiqupingjia         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.DaiqupingjiaVO" >
		SELECT  daiqupingjia.* FROM daiqupingjia  daiqupingjia 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.DaiqupingjiaView" >

		SELECT  daiqupingjia.* FROM daiqupingjia  daiqupingjia 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.DaiqupingjiaView" >
		SELECT * FROM daiqupingjia  daiqupingjia <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM daiqupingjia
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM daiqupingjia
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM daiqupingjia
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM daiqupingjia
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM daiqupingjia
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>




</mapper>
